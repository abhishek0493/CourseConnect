# Frontend (Vite) environment — copy to .env for local dev.
# These values are INLINED at build time (`vite build`), so changing them in
# production requires a re-deploy, not just an env edit.

VITE_ENV=development

# Production monolith: leave EMPTY so API calls are origin-relative (/api/v1),
# i.e. served by the same Express app. No host coupling.
VITE_BASE_URL=

# Local dev: the backend dev server origin (used when VITE_ENV != production).
VITE_SERVER_URL=http://localhost:8000
