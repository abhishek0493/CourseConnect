# Backend environment — copy to .env and fill in. NEVER commit real secrets.
# In production these are set in the Render dashboard (see render.yaml).

NODE_ENV=development
PORT=8000

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_COOKIE_EXPIRES_IN=7

# --- Database ---
# Local dev should point at your LOCAL MySQL. (Heads up: the legacy .env pointed
# DB_* at a remote ClearDB instance — make sure these are your local creds.)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=CourseConnect

# Managed MySQL (production) requires TLS — set DB_SSL=true there.
DB_SSL=false
# DB_CA=            # optional PEM CA cert contents for strict verification
# DB_POOL_MIN=2
# DB_POOL_MAX=10

# --- CORS / client origin ---
# Only needed when the client runs on a different origin (e.g. local dev on :3000).
CLIENT_URL=http://localhost:3000
