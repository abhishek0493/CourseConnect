# Pin npm resolution to match CI/Render (Node 20, npm 10) regardless of any
# developer's global ~/.npmrc. A global `legacy-peer-deps=true` makes npm SKIP
# auto-installed peer deps, producing an incomplete package-lock.json that then
# fails `npm ci` on Render (e.g. "Missing: @babel/core ... from lock file").
legacy-peer-deps=false
